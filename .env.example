# ╔══════════════════════════════════════════════════════════╗
# ║  SmartERP Backend — Required Environment Variables      ║
# ║  Copy to .env and fill in all values before running     ║
# ╚══════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL controls certificate verification for the DB connection:
#   true      → verify certificate (recommended for production)
#   no-verify → encrypt but skip cert check (some managed/hosted DBs require this)
#   false     → no SSL (local dev only)
DB_SSL=true

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
WEB_CONCURRENCY=2
BASE_URL=https://your-backend-url.onrender.com
BACKEND_URL=https://your-backend-url.onrender.com

# ── Auth / JWT ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Frontend Origins (for CORS) ───────────────────────────────
FRONTEND_ORIGIN=https://www.prozync.in
CUSTOMER_PORTAL_ORIGIN=https://client.prozync.in

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Firebase Admin SDK ────────────────────────────────────────
# Option A: Pass the full service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT=

# Option B: Individual fields (use either A or B, not both)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Groq AI ───────────────────────────────────────────────────
GROQ_API_KEY=

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Super Admin ───────────────────────────────────────────────
SUPER_ADMIN_EMAIL=

# ── Admin Panel ───────────────────────────────────────────────
# Choose a long random string — this is the URL segment for the super-admin panel
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# NEVER use the default or any guessable value
ADMIN_ROUTE=
